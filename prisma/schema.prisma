generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  PROPERTY_MANAGER
  OWNER
  TENANT
  GUEST
  VENDOR
  AGENT
  MAINTENANCE_STAFF
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  MIXED_USE
  SHORTLET
  LUXURY_RESIDENTIAL
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  UNDER_RENOVATION
  SOLD
}

enum UnitStatus {
  OCCUPIED
  VACANT
  RESERVED
  MAINTENANCE
  SHORTLET
}

enum LeaseStatus {
  ACTIVE
  EXPIRED
  PENDING
  TERMINATED
  RENEWED
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  PARTIAL
  REFUNDED
}

enum PaymentMethod {
  PAYSTACK
  FLUTTERWAVE
  STRIPE
  BANK_TRANSFER
  CASH
}

enum PaymentType {
  RENT
  DEPOSIT
  MAINTENANCE
  SHORTLET
  PENALTY
  REFUND
  LATE_FEE
  OTHER
}

enum InvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  PAID
  CANCELLED
}

enum InvoiceType {
  RENT
  SHORTLET
  SERVICE
  MAINTENANCE
  OTHER
}

enum WorkOrderPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
  ROUTINE
}

enum WorkOrderStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum KYCStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  DIRECT
  AIRBNB
  BOOKING_COM
  EXPEDIA
  OTHER
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  firstName String
  lastName  String
  phone     String?
  avatar    String?
  role      UserRole @default(TENANT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant?
  owner         Owner?
  vendor        Vendor?
  messages      Message[]      @relation("SentMessages")
  notifications Notification[]

  @@map("users")
}

model Property {
  id          String         @id @default(cuid())
  name        String
  type        PropertyType
  address     String
  city        String
  state       String
  country     String         @default("Nigeria")
  description String?
  totalUnits  Int            @default(0)
  images      String[]
  documents   String[]
  gpsLat      Float?
  gpsLng      Float?
  status      PropertyStatus @default(ACTIVE)
  healthScore Int            @default(100)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  units           Unit[]
  workOrders      WorkOrder[]
  inspections     Inspection[]
  contactLinks    CrmContactProperty[]
  tasks           CrmTask[]
  meetings        CrmMeeting[]

  @@map("properties")
}

model Unit {
  id            String     @id @default(cuid())
  propertyId    String
  unitNumber    String
  floor         Int        @default(1)
  bedrooms      Int        @default(1)
  bathrooms     Int        @default(1)
  sqMeters      Float?
  monthlyRent   Float
  nightlyRate   Float?
  depositAmount Float
  status        UnitStatus @default(VACANT)
  amenities     String[]
  photos        String[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  property    Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases      Lease[]
  workOrders  WorkOrder[]
  inspections Inspection[]
  bookings    ShortletBooking[]

  @@unique([propertyId, unitNumber])
  @@map("units")
}

model Tenant {
  id               String    @id @default(cuid())
  userId           String    @unique
  kycStatus        KYCStatus @default(PENDING)
  kycDocuments     String[]
  employerName     String?
  emergencyContact String?
  emergencyPhone   String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leases   Lease[]
  payments Payment[]

  @@map("tenants")
}

model Owner {
  id                String   @id @default(cuid())
  userId            String   @unique
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("owners")
}

model Vendor {
  id             String   @id @default(cuid())
  userId         String   @unique
  companyName    String
  specialization String[]
  rating         Float    @default(0)
  isVerified     Boolean  @default(false)
  bankName       String?
  bankAccount    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@map("vendors")
}

model Lease {
  id             String      @id @default(cuid())
  unitId         String
  tenantId       String
  startDate      DateTime
  endDate        DateTime
  rentAmount     Float
  depositAmount  Float
  depositPaid    Boolean     @default(false)
  status         LeaseStatus @default(PENDING)
  autoRenew      Boolean     @default(false)
  escalationRate Float?
  documentUrl    String?
  signedAt       DateTime?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  unit     Unit      @relation(fields: [unitId], references: [id])
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payments Payment[]

  @@map("leases")
}

model Payment {
  id         String        @id @default(cuid())
  tenantId   String
  leaseId    String?
  bookingId  String?
  amount     Float
  type       PaymentType
  method     PaymentMethod
  status     PaymentStatus @default(PENDING)
  reference  String        @unique
  gateway    String?
  receiptUrl String?
  dueDate    DateTime
  paidAt     DateTime?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  tenant  Tenant           @relation(fields: [tenantId], references: [id])
  lease   Lease?           @relation(fields: [leaseId], references: [id])
  booking ShortletBooking? @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model WorkOrder {
  id              String            @id @default(cuid())
  propertyId      String
  unitId          String?
  vendorId        String?
  raisedByUserId  String?
  title           String
  description     String
  category        String
  priority        WorkOrderPriority @default(MEDIUM)
  status          WorkOrderStatus   @default(OPEN)
  estimatedCost   Float?
  actualCost      Float?
  slaHours        Int               @default(24)
  photos          String[]
  completionNotes String?
  raisedAt        DateTime          @default(now())
  assignedAt      DateTime?
  completedAt     DateTime?
  rating          Int?
  review          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  property   Property @relation(fields: [propertyId], references: [id])
  unit       Unit?    @relation(fields: [unitId], references: [id])
  vendor     Vendor?  @relation(fields: [vendorId], references: [id])

  @@map("work_orders")
}

model Inspection {
  id           String    @id @default(cuid())
  propertyId   String
  unitId       String?
  type         String
  scheduledAt  DateTime
  completedAt  DateTime?
  inspectorId  String?
  photos       String[]
  videos       String[]
  findings     String?
  damageReport String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  unit     Unit?    @relation(fields: [unitId], references: [id])
  rating   Float?

  @@map("inspections")
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  type           InvoiceType
  status         InvoiceStatus @default(DRAFT)
  tenantId       String?
  vendorId       String?
  bookingId      String?
  recipientName  String
  recipientEmail String?
  description    String
  lineItems      Json          @default("[]")
  subtotal       Float         @default(0)
  taxRate        Float         @default(0)
  total          Float         @default(0)
  dueDate        DateTime
  issuedAt       DateTime      @default(now())
  approvedAt     DateTime?
  approvedBy     String?
  sentAt         DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("invoices")
}

model ShortletBooking {
  id              String        @id @default(cuid())
  unitId          String
  guestUserId     String?
  guestName       String
  guestEmail      String
  guestPhone      String
  checkIn         DateTime
  checkOut        DateTime
  nights          Int
  nightlyRate     Float
  totalAmount     Float
  source          BookingSource @default(DIRECT)
  status          BookingStatus @default(PENDING)
  guestCount      Int           @default(1)
  specialRequests String?
  checkInCode     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  unit     Unit      @relation(fields: [unitId], references: [id])
  payments Payment[]

  @@map("shortlet_bookings")
}

model Message {
  id        String    @id @default(cuid())
  senderId  String
  threadId  String?
  subject   String?
  body      String
  type      String    @default("DIRECT")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  sender User @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  channel   String    @default("IN_APP")
  data      Json?
  readAt    DateTime?
  sentAt    DateTime  @default(now())
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Document {
  id         String   @id @default(cuid())
  name       String
  url        String
  type       String
  folder     String   @default("General")
  size       Int?
  entityType String?
  entityId   String?
  uploadedBy String
  createdAt  DateTime @default(now())

  @@map("documents")
}

// ─── CRM ────────────────────────────────────────────────────────────────────

model CrmContact {
  id              String   @id @default(cuid())
  name            String
  type            String
  email           String?
  phone           String?
  company         String?
  location        String?
  source          String?
  notes           String?
  createdByUserId String?
  linkedRole      String?  // TENANT, OWNER, VENDOR, AGENT, MAINTENANCE_STAFF
  linkedUserId    String?  // links to User.id once converted
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deals      CrmDeal[]
  activities CrmContactActivity[]
  properties CrmContactProperty[]
  tasks      CrmTask[]
  meetings   CrmMeeting[]

  @@map("crm_contacts")
}

model CrmContactActivity {
  id             String   @id @default(cuid())
  contactId      String
  loggedByUserId String?
  loggedByName   String?
  type           String   // CALL_OUT, CALL_IN, EMAIL_OUT, EMAIL_IN, WHATSAPP, MEETING, SITE_VISIT, NOTE, SMS
  subject        String?
  body           String
  outcome        String?
  duration       Int?     // minutes (for calls/meetings)
  attachments    String[]
  activityAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contact CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("crm_contact_activities")
}

model CrmContactProperty {
  id         String   @id @default(cuid())
  contactId  String
  propertyId String
  interest   String   @default("Interested") // Buyer, Tenant, Investor, Interested
  notes      String?
  createdAt  DateTime @default(now())

  contact  CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([contactId, propertyId])
  @@map("crm_contact_properties")
}

model CrmPipeline {
  id          String   @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean  @default(false)
  color       String   @default("#1e3a5f")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages CrmPipelineStage[]
  deals  CrmDeal[]

  @@map("crm_pipelines")
}

model CrmPipelineStage {
  id          String   @id @default(cuid())
  pipelineId  String
  name        String
  order       Int
  color       String   @default("#6B7280")
  probability Int      @default(30)
  isWon       Boolean  @default(false)
  isLost      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pipeline CrmPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    CrmDeal[]

  @@map("crm_pipeline_stages")
}

model CrmDeal {
  id                String    @id @default(cuid())
  title             String
  contactId         String?
  contactName       String
  value             Float     @default(0)
  stage             String    @default("Enquiry")  // kept for backward compat
  probability       Int       @default(30)
  expectedCloseDate DateTime?
  dueDate           DateTime?
  notes             String?
  pipelineId        String?
  pipelineStageId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  contact       CrmContact?       @relation(fields: [contactId], references: [id])
  tasks         CrmTask[]
  meetings      CrmMeeting[]
  pipeline      CrmPipeline?      @relation(fields: [pipelineId], references: [id])
  pipelineStage CrmPipelineStage? @relation(fields: [pipelineStageId], references: [id])

  @@map("crm_deals")
}

model CrmMeeting {
  id              String    @id @default(cuid())
  title           String
  type            String    @default("PHYSICAL") // VIRTUAL, PHYSICAL
  status          String    @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED, RESCHEDULED
  scheduledAt     DateTime
  duration        Int       @default(60) // minutes
  location        String?
  meetingUrl      String?
  brief           String?
  outcome         String?
  attendees       Json      @default("[]") // [{name, email?, role?}]
  contactId       String?
  dealId          String?
  propertyId      String?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contact  CrmContact? @relation(fields: [contactId], references: [id])
  deal     CrmDeal?    @relation(fields: [dealId], references: [id])
  property Property?   @relation(fields: [propertyId], references: [id])

  @@map("crm_meetings")
}

model CrmTask {
  id               String    @id @default(cuid())
  title            String
  description      String?
  type             String    @default("TASK") // TASK, CALL, EMAIL, FOLLOW_UP, MEETING, REMINDER, SITE_VISIT, INSPECTION
  status           String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  priority         String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  dueAt            DateTime?
  completedAt      DateTime?
  tags             String[]
  notes            String?
  // Entity links
  contactId        String?
  dealId           String?
  propertyId       String?
  // Assignment
  createdByUserId  String?
  assignedToUserId String?
  assignedToName   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  contact  CrmContact? @relation(fields: [contactId], references: [id])
  deal     CrmDeal?    @relation(fields: [dealId], references: [id])
  property Property?   @relation(fields: [propertyId], references: [id])

  @@map("crm_tasks")
}

model CrmCommission {
  id               String    @id @default(cuid())
  agentUserId      String?
  agent            String
  property         String
  dealValue        Float     @default(0)
  commissionRate   Float     @default(3)
  commissionAmount Float     @default(0)
  type             String    @default("Sale")
  status           String    @default("Pending")
  saleDate         DateTime?
  paidDate         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("crm_commissions")
}

model CrmTrainingProgram {
  id          String    @id @default(cuid())
  title       String
  category    String
  trainer     String
  targetRole  String    @default("All")
  startDate   DateTime
  endDate     DateTime?
  venue       String?
  capacity    Int       @default(20)
  enrolled    Int       @default(0)
  status      String    @default("Upcoming")
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("crm_training_programs")
}

model CrmDossier {
  id             String   @id @default(cuid())
  title          String
  type           String
  location       String
  totalUnits     Int      @default(0)
  priceFrom      Float    @default(0)
  priceTo        Float    @default(0)
  developer      String
  completionDate String?
  yieldEstimate  Float    @default(0)
  targetInvestor String?
  highlights     String?
  status         String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("crm_dossiers")
}

model CrmTeamMember {
  id         String   @id @default(cuid())
  name       String
  role       String
  email      String
  phone      String?
  target     Float    @default(0)
  achieved   Float    @default(0)
  active     Boolean  @default(true)
  avatar     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("crm_team_members")
}

model CrmSubscription {
  id                 String    @id @default(cuid())
  subscriber         String
  email              String
  phone              String?
  type               String    @default("Prospect")
  interests          String[]
  budget             String?
  preferredLocations String?
  frequency          String    @default("Weekly")
  status             String    @default("Active")
  lastNotified       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("crm_subscriptions")
}
